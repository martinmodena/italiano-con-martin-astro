const documentHtml = "<!doctype html>\n<!-- Generated from legacy-html by scripts/import-html.mjs: letture/api-linguaggio-e-caratteristiche.html -->\n<html lang=\"it\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <title>Le api: caratteristiche e linguaggio A1-C1 | Italiano con Martin</title>\n  <meta name=\"description\" content=\"Le api: lettura graduata A1-C1 su alveare, impollinazione, danza dell&#8217;addome e comunicazione animale.\">\n  <link rel=\"canonical\" href=\"https://italianoconmartin.com/letture/api-linguaggio-e-caratteristiche.html\">\n  <meta name=\"robots\" content=\"index,follow,max-image-preview:large\">\n  <meta name=\"author\" content=\"Martin Modena\">\n  <meta property=\"og:type\" content=\"website\">\n  <meta property=\"og:site_name\" content=\"Italiano con Martin\">\n  <meta property=\"og:title\" content=\"Le api: caratteristiche e linguaggio A1-C1 | Italiano con Martin\">\n  <meta property=\"og:description\" content=\"Le api non producono solo miele: organizzano una societ&#224; complessa e comunicano la posizione del cibo con una danza.\">\n  <meta property=\"og:url\" content=\"https://italianoconmartin.com/letture/api-linguaggio-e-caratteristiche.html\">\n  <meta property=\"og:image\" content=\"https://italianoconmartin.com/assets/reading-api-linguaggio.webp\">\n  <meta property=\"og:image:width\" content=\"960\">\n  <meta property=\"og:image:height\" content=\"540\">\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\n  <meta name=\"twitter:title\" content=\"Le api: caratteristiche e linguaggio A1-C1 | Italiano con Martin\">\n  <meta name=\"twitter:description\" content=\"Le api non producono solo miele: organizzano una societ&#224; complessa e comunicano la posizione del cibo con una danza.\">\n  <meta name=\"twitter:image\" content=\"https://italianoconmartin.com/assets/reading-api-linguaggio.webp\">\n  <script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"url\":\"https://italianoconmartin.com/letture/api-linguaggio-e-caratteristiche.html\",\"headline\":\"Le api: caratteristiche e linguaggio\",\"inLanguage\":\"it\",\"educationalLevel\":\"A1-C1\",\"image\":\"https://italianoconmartin.com/assets/reading-api-linguaggio.webp\"}</script>\n  <link rel=\"stylesheet\" href=\"../styles.css\">\n  <link rel=\"icon\" href=\"../favicon.png\" type=\"image/png\">\n  <link rel=\"apple-touch-icon\" href=\"../apple-touch-icon.png\">\n</head>\n<body>\n<header class=\"site-header\">\n  <div class=\"container nav-wrap\">\n    <a class=\"brand\" href=\"../\"><img class=\"brand-avatar\" src=\"../assets/martin-photo.svg\" alt=\"Martin\"><span>Italiano con Martin</span></a>\n    <nav><a href=\"../letture/\">Letture</a><a href=\"../grammatica/\">Grammatica</a><a class=\"nav-cta\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></nav>\n  </div>\n</header>\n<main>\n  <section class=\"story-hero\">\n    <div class=\"container\">\n      <p class=\"breadcrumbs\"><a href=\"../\">Home</a> / <a href=\"./\">Letture</a> / Le api: caratteristiche e linguaggio</p>\n      <div class=\"story-hero-grid\">\n        <div>\n          <p class=\"eyebrow\">Scienza - lettura graduata</p>\n          <h1>Le api: caratteristiche e linguaggio</h1>\n          <p class=\"lead\">Le api non producono solo miele: organizzano una societ&#224; complessa e comunicano la posizione del cibo con una danza.</p>\n          <div class=\"level-nav\"><a href=\"#a1\">A1</a><a href=\"#a2\">A2</a><a href=\"#b1\">B1</a><a href=\"#b2\">B2</a><a href=\"#c1\">C1</a></div>\n        </div>\n        <figure class=\"story-figure\">\n          <img src=\"../assets/reading-api-linguaggio.webp\" alt=\"Api su un favo in un prato con una traccia di danza nell&#8217;aria\" width=\"960\" height=\"540\" decoding=\"async\">\n          <figcaption>La danza delle api trasforma direzione, distanza e qualit&#224; del cibo in movimento.</figcaption>\n        </figure>\n      </div>\n    </div>\n  </section>\n  <section class=\"section compact-top\">\n    <div class=\"container\">\n      <article class=\"story-card\" id=\"a1\">\n        <header><div><span class=\"level\">A1</span><h2>Le api: caratteristiche e linguaggio - livello A1</h2></div><p>Presente</p></header>\n        <div class=\"story-text\">\n          <p>Le api sono piccoli insetti molto importanti. Vivono in gruppo, dentro un alveare.</p>\n          <p>Le api volano sui fiori e prendono nettare e polline. Con il nettare fanno il miele.</p>\n          <p>Quando visitano i fiori, aiutano anche le piante. Questo lavoro si chiama impollinazione.</p>\n          <p>Nell&#8217;alveare ci sono molte api operaie, una regina e, in certi periodi, i fuchi.</p>\n          <p>Le api comunicano anche con una danza. Un&#8217;ape pu&#242; dire alle altre dove trovare fiori buoni.</p>\n        </div>\n        <div class=\"learning-grid\"><div><h3>Scheda lessico</h3><p>ape, fiore, miele, alveare, danza, polline</p></div><div><h3>Scheda attiva</h3><ol><li>Riassumi l&#8217;idea principale con parole tue.</li><li>Scegli due parole nuove e usale in una frase personale.</li></ol></div></div>\n      </article>\n      <article class=\"story-card\" id=\"a2\">\n        <header><div><span class=\"level\">A2</span><h2>Le api: caratteristiche e linguaggio - livello A2</h2></div><p>Descrizione A2</p></header>\n        <div class=\"story-text\">\n          <p>Le api sono insetti sociali: vivono in una comunit&#224; organizzata, dove ogni individuo ha un compito.</p>\n          <p>Alcune api cercano nettare e polline, altre proteggono l&#8217;alveare, altre puliscono o curano le larve.</p>\n          <p>La danza delle api &#232; sorprendente. Con movimenti precisi, un&#8217;ape informa le compagne sulla direzione e sulla distanza dei fiori.</p>\n          <p>Se il cibo &#232; vicino, la danza &#232; pi&#249; semplice. Se il cibo &#232; lontano, la danza diventa pi&#249; complessa e somiglia a un otto.</p>\n          <p>Le api sono fondamentali per l&#8217;ambiente perch&#233; aiutano molte piante a riprodursi e sostengono una parte importante dell&#8217;agricoltura.</p>\n        </div>\n        <div class=\"learning-grid\"><div><h3>Scheda lessico</h3><p>insetti sociali, nettare, polline, larve, regina</p></div><div><h3>Scheda attiva</h3><ol><li>Riassumi l&#8217;idea principale con parole tue.</li><li>Scegli due parole nuove e usale in una frase personale.</li></ol></div></div>\n      </article>\n      <article class=\"story-card\" id=\"b1\">\n        <header><div><span class=\"level\">B1</span><h2>Le api: caratteristiche e linguaggio - livello B1</h2></div><p>Relazioni e cause</p></header>\n        <div class=\"story-text\">\n          <p>Le api mostrano una forma di organizzazione sorprendente. L&#8217;alveare funziona grazie alla collaborazione di migliaia di individui.</p>\n          <p>La danza dell&#8217;addome &#232; uno dei sistemi di comunicazione animale pi&#249; studiati. Non &#232; un gesto casuale: contiene informazioni utili per le altre api.</p>\n          <p>La direzione della parte dritta della danza indica l&#8217;angolo rispetto al sole. La durata del movimento comunica informazioni sulla distanza.</p>\n          <p>Le api non indicano solo &#8220;c&#8217;&#232; cibo&#8221;. Possono comunicare anche quanto una fonte sia interessante, perch&#233; una fonte ricca produce danze pi&#249; intense o pi&#249; ripetute.</p>\n          <p>Proteggere le api significa proteggere anche biodiversit&#224;, frutta, semi e molte coltivazioni che dipendono dagli impollinatori.</p>\n        </div>\n        <div class=\"learning-grid\"><div><h3>Scheda lessico</h3><p>collaborazione, fonte di cibo, comunicazione animale, biodiversit&#224;, impollinatori</p></div><div><h3>Scheda attiva</h3><ol><li>Riassumi l&#8217;idea principale con parole tue.</li><li>Scegli due parole nuove e usale in una frase personale.</li></ol></div></div>\n      </article>\n      <article class=\"story-card\" id=\"b2\">\n        <header><div><span class=\"level\">B2</span><h2>Le api: caratteristiche e linguaggio - livello B2</h2></div><p>Lessico specifico</p></header>\n        <div class=\"story-text\">\n          <p>Le api sono spesso associate al miele, ma il loro valore ecologico va molto oltre. Come impollinatori, contribuiscono alla riproduzione di numerose specie vegetali.</p>\n          <p>La danza dell&#8217;addome traduce un&#8217;informazione spaziale in un codice corporeo. La posizione del sole diventa un riferimento, mentre la gravit&#224; sul favo aiuta a orientare il movimento.</p>\n          <p>Il sistema non &#232; perfetto come un GPS. Le api reclutate arrivano in una zona probabile e poi usano odori, colori e segnali dell&#8217;ambiente per trovare i fiori.</p>\n          <p>Un fatto poco noto &#232; che la distanza comunicata dipende anche dal paesaggio: vento, ostacoli e fatica influenzano l&#8217;esperienza del volo.</p>\n          <p>Pesticidi, perdita di habitat, malattie e cambiamento climatico rendono la vita delle colonie pi&#249; difficile. Il problema non riguarda solo le api, ma l&#8217;equilibrio degli ecosistemi.</p>\n        </div>\n        <div class=\"learning-grid\"><div><h3>Scheda lessico</h3><p>impollinatori, codice corporeo, favo, ecosistema, pesticidi</p></div><div><h3>Scheda attiva</h3><ol><li>Riassumi l&#8217;idea principale con parole tue.</li><li>Scegli due parole nuove e usale in una frase personale.</li></ol></div></div>\n      </article>\n      <article class=\"story-card\" id=\"c1\">\n        <header><div><span class=\"level\">C1</span><h2>Le api: caratteristiche e linguaggio - livello C1</h2></div><p>Divulgazione avanzata</p></header>\n        <div class=\"story-text\">\n          <p>L&#8217;alveare rappresenta un modello affascinante di intelligenza distribuita. Nessuna ape possiede una visione completa del sistema, eppure la colonia regola lavoro, difesa, nutrizione e riproduzione.</p>\n          <p>La danza mostra come un&#8217;informazione spaziale possa essere tradotta in movimento. La durata della fase vibrante fornisce indizi sulla distanza; l&#8217;orientamento rispetto alla verticale rimanda alla direzione rispetto al sole.</p>\n          <p>La comunicazione non elimina l&#8217;incertezza. L&#8217;ape danzatrice porta anche odori dei fiori visitati, e questi indizi aiutano le compagne a completare la ricerca fuori dall&#8217;alveare.</p>\n          <p>Studi recenti suggeriscono che alcune api possano usare le informazioni della danza non solo come istruzioni di volo, ma come indicazioni da integrare con una rappresentazione pi&#249; ampia del territorio.</p>\n          <p>Studiare le api significa osservare insieme natura, cooperazione, linguaggio non umano e vulnerabilit&#224; ambientale. &#200; un tema perfetto per imparare lessico scientifico senza perdere il legame con la vita quotidiana.</p>\n        </div>\n        <div class=\"learning-grid\"><div><h3>Scheda lessico</h3><p>intelligenza distribuita, informazione spaziale, orientamento, vulnerabilit&#224;, territorio</p></div><div><h3>Scheda attiva</h3><ol><li>Riassumi l&#8217;idea principale con parole tue.</li><li>Scegli due parole nuove e usale in una frase personale.</li></ol></div></div>\n      </article>\n      <article class=\"story-card\">\n        <header><div><span class=\"level\">INFO</span><h2>Tre cose poco conosciute</h2></div><p>Per parlarne in classe</p></header>\n        <div class=\"story-text\">\n          <p><strong>1. La danza a otto comunica direzione e distanza, non solo entusiasmo.</strong></p>\n          <p><strong>2. L&#8217;odore dei fiori resta importante:</strong> la danza guida, ma non sostituisce tutti gli altri sensi.</p>\n          <p><strong>3. La colonia funziona come una rete:</strong> molte decisioni emergono da azioni locali, non da un comando centrale.</p>\n        </div>\n      </article>\n      <article class=\"story-card\">\n        <header><div><span class=\"level\">Fonti</span><h2>Fonti usate</h2></div><p>Per approfondire</p></header>\n        <div class=\"story-text\">\n          <p>NC State Extension, <a href=\"https://content.ces.ncsu.edu/honey-bee-dance-language\" target=\"_blank\" rel=\"noopener\">The Honey Bee Dance Language</a>.</p>\n          <p>ScienceDirect Topics, <a href=\"https://www.sciencedirect.com/topics/veterinary-science-and-veterinary-medicine/waggle-dance\" target=\"_blank\" rel=\"noopener\">Waggle Dance</a>.</p>\n          <p>PNAS / PMC, <a href=\"https://pmc.ncbi.nlm.nih.gov/articles/PMC10041085/\" target=\"_blank\" rel=\"noopener\">Honey bees infer source location from dances</a>.</p>\n        </div>\n      </article>\n    </div>\n  </section>\n  <section class=\"conversion-section\">\n    <div class=\"container conversion-card\">\n      <div><h2>Vuoi trasformare questa lettura in conversazione?</h2><p>Leggi il livello giusto per te e portiamo parole, idee e dubbi in una lezione individuale.</p></div>\n      <div class=\"conversion-actions\"><a class=\"button light\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></div>\n    </div>\n  </section>\n</main>\n<footer><div class=\"container footer-grid\"><div><strong>Italiano con Martin</strong><p>Letture graduate, grammatica chiara e lezioni online.</p></div><div><a href=\"../letture/\">Letture</a><a href=\"../grammatica/\">Grammatica</a></div></div></footer>\n<script src=\"../script.js\"></script>\n</body>\n</html>\n";
