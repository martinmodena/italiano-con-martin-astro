const documentHtml = "<!doctype html>\n<!-- Generated from legacy-html by scripts/import-html.mjs: grammatica/a2/futuro-semplice.html -->\r\n<html lang=\"it\">\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\r\n  <title>Futuro semplice - livello A2 | Italiano con Martin</title>\r\n  <meta name=\"description\" content=\"Impara il futuro semplice italiano con forme regolari, verbi irregolari, esempi pratici ed esercizi interattivi.\">\r\n  \r\n  <link rel=\"canonical\" href=\"https://italianoconmartin.com/grammatica/a2/futuro-semplice.html\">\r\n  <meta name=\"robots\" content=\"index,follow,max-image-preview:large\">\r\n  <meta name=\"author\" content=\"Martin Modena\">\r\n  <meta property=\"og:type\" content=\"website\">\r\n  <meta property=\"og:site_name\" content=\"Italiano con Martin\">\r\n  <meta property=\"og:title\" content=\"Futuro semplice - livello A2 | Italiano con Martin\">\r\n  <meta property=\"og:description\" content=\"Impara il futuro semplice italiano con forme regolari, verbi irregolari, esempi pratici ed esercizi interattivi.\">\r\n  <meta property=\"og:url\" content=\"https://italianoconmartin.com/grammatica/a2/futuro-semplice.html\">\r\n  <meta property=\"og:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\r\n  <meta name=\"twitter:title\" content=\"Futuro semplice - livello A2 | Italiano con Martin\">\r\n  <meta name=\"twitter:description\" content=\"Impara il futuro semplice italiano con forme regolari, verbi irregolari, esempi pratici ed esercizi interattivi.\">\r\n  <meta name=\"twitter:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <link rel=\"stylesheet\" href=\"../../styles.css\">\r\n  \r\n  <link rel=\"stylesheet\" href=\"../../assets/grammar-lesson.css\">\r\n  <link rel=\"icon\" href=\"../../favicon.png\" type=\"image/png\"><link rel=\"apple-touch-icon\" href=\"../../apple-touch-icon.png\">\r\n</head>\r\n<body data-lesson=\"martin-futuro-semplice-a2\">\r\n<header class=\"site-header\"><div class=\"container nav-wrap\"><a class=\"brand\" href=\"../../\"><img class=\"brand-avatar\" src=\"../../assets/martin-photo.svg\" alt=\"Martin\" width=\"48\" height=\"48\" decoding=\"async\"><span>Italiano con Martin</span></a><nav><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a><a class=\"nav-cta\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></nav></div></header>\r\n<main>\r\n  <section class=\"page-intro\"><div class=\"container lesson-shell\"><p class=\"breadcrumbs\"><a href=\"../../\">Home</a> / <a href=\"../\">Grammatica</a> / A2 / Futuro semplice</p><p class=\"eyebrow\">Grammatica A2</p><h1>Il futuro semplice</h1><p class=\"lead\">Parla di programmi, previsioni e promesse: domani studierò, partirai, faremo pratica.</p><div class=\"lesson-meta\"><span>12 minuti</span><span>10 esercizi</span><span>Livello A2</span></div><div class=\"lesson-nav\"><a href=\"#forma\">Forma</a><a href=\"#usi\">Usi</a><a href=\"#irregolari\">Irregolari</a><a href=\"#esercizi\">Esercizi</a></div></div></section>\r\n  <section class=\"section compact-top\"><div class=\"container lesson-shell\">\r\n    <article class=\"lesson-box\" id=\"forma\"><h2>Come si forma?</h2><p>Per molti verbi togliamo la finale dell'infinito e aggiungiamo le desinenze del futuro.</p><table class=\"conj-table\"><thead><tr><th>Persona</th><th>Parlare</th><th>Prendere</th><th>Partire</th></tr></thead><tbody><tr><td>io</td><td>parlerò</td><td>prenderò</td><td>partirò</td></tr><tr><td>tu</td><td>parlerai</td><td>prenderai</td><td>partirai</td></tr><tr><td>lui / lei</td><td>parlerà</td><td>prenderà</td><td>partirà</td></tr><tr><td>noi</td><td>parleremo</td><td>prenderemo</td><td>partiremo</td></tr><tr><td>voi</td><td>parlerete</td><td>prenderete</td><td>partirete</td></tr><tr><td>loro</td><td>parleranno</td><td>prenderanno</td><td>partiranno</td></tr></tbody></table><p class=\"mini-note\"><strong>Nota:</strong> nei verbi in -are la A diventa E: parlare → parlerò, mangiare → mangerò.</p></article>\r\n    <article class=\"lesson-box\" id=\"usi\"><h2>Quando lo usiamo?</h2><div class=\"rule-grid\"><div class=\"rule-card\"><strong>Programmi</strong><br>Domani visiterò il centro.</div><div class=\"rule-card\"><strong>Previsioni</strong><br>Secondo me pioverà.</div><div class=\"rule-card\"><strong>Promesse</strong><br>Ti chiamerò stasera.</div><div class=\"rule-card\"><strong>Ipotesi sul presente</strong><br>Sarà a casa? = forse è a casa.</div></div></article>\r\n    <article class=\"lesson-box\" id=\"irregolari\"><h2>Futuri irregolari frequenti</h2><table class=\"conj-table\"><thead><tr><th>Infinito</th><th>Base futura</th><th>Esempio</th></tr></thead><tbody><tr><td>essere</td><td>sar-</td><td>sarò, sarai, sarà</td></tr><tr><td>avere</td><td>avr-</td><td>avrò, avrai, avrà</td></tr><tr><td>andare</td><td>andr-</td><td>andrò, andrai, andrà</td></tr><tr><td>fare</td><td>far-</td><td>farò, farai, farà</td></tr><tr><td>venire</td><td>verr-</td><td>verrò, verrai, verrà</td></tr><tr><td>potere</td><td>potr-</td><td>potrò, potrai, potrà</td></tr></tbody></table></article>\r\n    <article class=\"lesson-box\"><h2>Errori comuni</h2><div class=\"mistake-grid\"><div class=\"mistake\"><strong>Errato: io parleraio.</strong>Corretto: io parlerò.</div><div class=\"mistake\"><strong>Errato: domani vado a Roma, sempre.</strong>Corretto: domani andrò a Roma.</div><div class=\"mistake\"><strong>Errato: loro partirà.</strong>Corretto: loro partiranno.</div><div class=\"mistake\"><strong>Errato: io andarò.</strong>Corretto: io andrò.</div></div></article>\r\n    <article class=\"lesson-box\" id=\"esercizi\"><h2>Esercizi con feedback immediato</h2><p>Scrivi il futuro semplice.</p><div class=\"exercise\" data-answer=\"parlerò\" data-alt=\"parlero\" data-hint=\"Io + parlare: parlerò.\"><label>1. Io ___ con Martin. (parlare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"partirai\" data-hint=\"Tu + partire: partirai.\"><label>2. Tu ___ domani. (partire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"prenderà\" data-alt=\"prendera\" data-hint=\"Lei + prendere: prenderà.\"><label>3. Lei ___ il treno. (prendere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"mangeremo\" data-hint=\"Noi + mangiare: mangeremo.\"><label>4. Noi ___ alle otto. (mangiare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"vedrete\" data-hint=\"Voi + vedere: vedrete.\"><label>5. Voi ___ il risultato. (vedere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"saranno\" data-hint=\"Essere è irregolare: loro saranno.\"><label>6. Loro ___ felici. (essere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"andrò\" data-alt=\"andro\" data-hint=\"Andare è irregolare: andrò.\"><label>7. Io ___ in Italia. (andare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"farai\" data-hint=\"Fare è irregolare: farai.\"><label>8. Tu ___ gli esercizi. (fare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"avremo\" data-hint=\"Avere è irregolare: avremo.\"><label>9. Noi ___ tempo. (avere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"verranno\" data-hint=\"Venire è irregolare: verranno.\"><label>10. I miei amici ___ stasera. (venire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"score-card\"><div><strong>Il tuo risultato</strong><p id=\"score-text\">0 risposte corrette su 10</p></div><strong id=\"score-percent\">0%</strong></div><div class=\"exercise-actions\"><button class=\"reset-btn\" id=\"reset-exercises\" type=\"button\">Ricomincia</button><a class=\"button primary\" href=\"../\">Torna alla grammatica</a></div></article>\r\n  </div></section>\r\n  <section class=\"conversion-section\"><div class=\"container conversion-card\"><div><p class=\"eyebrow\">Parla dei tuoi progetti</p><h2>Il futuro serve subito in conversazione.</h2><p>Possiamo usarlo per raccontare viaggi, obiettivi e programmi di studio.</p></div><div class=\"conversion-actions\"><a class=\"button light\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></div></div></section>\r\n</main>\r\n<footer><div class=\"container footer-grid\"><div><strong>Italiano con Martin</strong><p>Grammatica chiara, letture graduate e lezioni online.</p></div><div><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a></div></div></footer><script src=\"../../assets/grammar-exercises.js\"></script>\r\n<script src=\"../../script.js\"></script></body>\r\n</html>\r\n\r\n\r\n";
