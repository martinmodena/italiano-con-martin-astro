const documentHtml = "<!doctype html>\n<!-- Generated from legacy-html by scripts/import-html.mjs: grammatica/a2/passato-prossimo-o-imperfetto.html -->\r\n<html lang=\"it\">\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\r\n  <title>Passato prossimo o imperfetto - livello A2 | Italiano con Martin</title>\r\n  <meta name=\"description\" content=\"Impara quando usare passato prossimo e imperfetto in italiano con confronti chiari, esempi ed esercizi interattivi.\">\r\n  \r\n  <link rel=\"canonical\" href=\"https://italianoconmartin.com/grammatica/a2/passato-prossimo-o-imperfetto.html\">\r\n  <meta name=\"robots\" content=\"index,follow,max-image-preview:large\">\r\n  <meta name=\"author\" content=\"Martin Modena\">\r\n  <meta property=\"og:type\" content=\"website\">\r\n  <meta property=\"og:site_name\" content=\"Italiano con Martin\">\r\n  <meta property=\"og:title\" content=\"Passato prossimo o imperfetto - livello A2 | Italiano con Martin\">\r\n  <meta property=\"og:description\" content=\"Impara quando usare passato prossimo e imperfetto in italiano con confronti chiari, esempi ed esercizi interattivi.\">\r\n  <meta property=\"og:url\" content=\"https://italianoconmartin.com/grammatica/a2/passato-prossimo-o-imperfetto.html\">\r\n  <meta property=\"og:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\r\n  <meta name=\"twitter:title\" content=\"Passato prossimo o imperfetto - livello A2 | Italiano con Martin\">\r\n  <meta name=\"twitter:description\" content=\"Impara quando usare passato prossimo e imperfetto in italiano con confronti chiari, esempi ed esercizi interattivi.\">\r\n  <meta name=\"twitter:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <link rel=\"stylesheet\" href=\"../../styles.css\">\r\n  \r\n  <link rel=\"stylesheet\" href=\"../../assets/grammar-lesson.css\">\r\n<link rel=\"icon\" href=\"../../favicon.png\" type=\"image/png\"><link rel=\"apple-touch-icon\" href=\"../../apple-touch-icon.png\"></head>\r\n<body data-lesson=\"martin-passato-imperfetto-a2\">\r\n<header class=\"site-header\"><div class=\"container nav-wrap\"><a class=\"brand\" href=\"../../\"><img class=\"brand-avatar\" src=\"../../assets/martin-photo.svg\" alt=\"Martin\" width=\"48\" height=\"48\" decoding=\"async\"><span>Italiano con Martin</span></a><nav><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a><a class=\"nav-cta\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></nav></div></header>\r\n<main>\r\n  <section class=\"page-intro\">\r\n    <div class=\"container lesson-shell\">\r\n      <p class=\"breadcrumbs\"><a href=\"../../\">Home</a> / <a href=\"../\">Grammatica</a> / A2 / Passato prossimo o imperfetto</p>\r\n      <p class=\"eyebrow\">Grammatica A2</p>\r\n      <h1>Passato prossimo o imperfetto?</h1>\r\n      <p class=\"lead\">Impara a scegliere tra azione conclusa, abitudine, descrizione e situazione in corso.</p>\r\n      <div class=\"lesson-meta\"><span>16 minuti</span><span>12 esercizi</span><span>Livello A2</span></div>\r\n      <div class=\"lesson-nav\"><a href=\"#scelta\">Scelta</a><a href=\"#confronti\">Confronti</a><a href=\"#errori\">Errori</a><a href=\"#esercizi\">Esercizi</a></div>\r\n    </div>\r\n  </section>\r\n\r\n  <section class=\"section compact-top\">\r\n    <div class=\"container lesson-shell\">\r\n      <article class=\"lesson-box\" id=\"scelta\">\r\n        <h2>La differenza principale</h2>\r\n        <div class=\"rule-grid\">\r\n          <div class=\"rule-card\"><strong>Passato prossimo</strong><br>Azione finita, evento preciso.<br><em>Ieri ho studiato italiano.</em></div>\r\n          <div class=\"rule-card\"><strong>Imperfetto</strong><br>Abitudine, descrizione, situazione.<br><em>Da bambino studiavo poco.</em></div>\r\n          <div class=\"rule-card\"><strong>Evento</strong><br><em>Alle otto sono uscito.</em></div>\r\n          <div class=\"rule-card\"><strong>Contesto</strong><br><em>Era tardi e pioveva.</em></div>\r\n        </div>\r\n        <p class=\"italian-box\"><strong>Trucco utile:</strong> se puoi dire \"che cosa e successo?\", spesso usi il passato prossimo. Se descrivi \"com'era la situazione?\", spesso usi l'imperfetto.</p>\r\n      </article>\r\n\r\n      <article class=\"lesson-box\" id=\"confronti\">\r\n        <h2>Confronti chiari</h2>\r\n        <table class=\"conj-table\">\r\n          <thead><tr><th>Situazione</th><th>Tempo</th><th>Esempio</th></tr></thead>\r\n          <tbody>\r\n            <tr><td>Azione conclusa</td><td>Passato prossimo</td><td>Ho finito il corso.</td></tr>\r\n            <tr><td>Abitudine nel passato</td><td>Imperfetto</td><td>Andavo al corso ogni martedi.</td></tr>\r\n            <tr><td>Descrizione</td><td>Imperfetto</td><td>La lezione era interessante.</td></tr>\r\n            <tr><td>Azione che interrompe</td><td>Passato prossimo</td><td>Mentre studiavo, ha chiamato Anna.</td></tr>\r\n            <tr><td>Azione in corso</td><td>Imperfetto</td><td>Mentre studiavo, ha chiamato Anna.</td></tr>\r\n          </tbody>\r\n        </table>\r\n        <h3>Mini storia</h3>\r\n        <p>Quando <strong>vivevo</strong> a Roma, <strong>prendevo</strong> spesso l'autobus. Un giorno <strong>ho incontrato</strong> un vecchio amico e <strong>abbiamo parlato</strong> per un'ora.</p>\r\n      </article>\r\n\r\n      <article class=\"lesson-box\" id=\"errori\">\r\n        <h2>Errori che fanno quasi tutti</h2>\r\n        <div class=\"mistake-grid\">\r\n          <div class=\"mistake\"><strong>Errato: Da bambino ho giocato ogni giorno.</strong>Meglio: da bambino giocavo ogni giorno.</div>\r\n          <div class=\"mistake\"><strong>Errato: Ieri andavo al cinema.</strong>Meglio: ieri sono andato al cinema.</div>\r\n          <div class=\"mistake\"><strong>Errato: Era caduto mentre camminava.</strong>Meglio A2: e caduto mentre camminava.</div>\r\n          <div class=\"mistake\"><strong>Errato: Quando ho avuto 10 anni...</strong>Meglio: quando avevo 10 anni...</div>\r\n        </div>\r\n      </article>\r\n\r\n      <article class=\"lesson-box\" id=\"esercizi\">\r\n        <h2>Esercizi con feedback immediato</h2>\r\n        <p>Scegli e scrivi la forma corretta.</p>\r\n        <div class=\"exercise\" data-answer=\"ho studiato\" data-hint=\"Ieri indica un evento concluso: passato prossimo.\"><label>1. Ieri ___ italiano. (studiare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"studiavo\" data-hint=\"Ogni sera indica un'abitudine: imperfetto.\"><label>2. Quando ero studente, ___ ogni sera. (studiare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"era\" data-hint=\"Descrizione della situazione: imperfetto.\"><label>3. La casa ___ molto piccola. (essere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"sono uscito\" data-answer-fem=\"sono uscita\" data-alt=\"sono uscita\" data-hint=\"Azione conclusa: passato prossimo.\"><label>4. Alle otto ___ di casa. (uscire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"pioveva\" data-hint=\"Descrive il tempo: imperfetto.\"><label>5. Quando sono uscito, ___. (piovere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"ha telefonato\" data-hint=\"Azione che interrompe: passato prossimo.\"><label>6. Mentre cucinavo, Marco ___. (telefonare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"cucinavo\" data-hint=\"Azione in corso: imperfetto.\"><label>7. Mentre ___, Marco ha telefonato. (cucinare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"avevo\" data-hint=\"Eta nel passato: imperfetto.\"><label>8. Quando ___ dieci anni, vivevo in campagna. (avere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"ho comprato\" data-hint=\"Evento concluso: passato prossimo.\"><label>9. Sabato ___ un libro. (comprare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"leggevo\" data-hint=\"Abitudine nel passato: imperfetto.\"><label>10. Da piccolo ___ molte favole. (leggere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"sono arrivato\" data-alt=\"sono arrivata|siamo arrivati|siamo arrivate\" data-hint=\"Evento concluso: passato prossimo. Con arrivare si usa essere: sono arrivato/a oppure siamo arrivati/e.\"><label>11. Alla fine ___ a Roma. (arrivare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"faceva\" data-hint=\"Descrizione del tempo: imperfetto.\"><label>12. In montagna ___ freddo. (fare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"score-card\"><div><strong>Il tuo risultato</strong><p id=\"score-text\">0 risposte corrette su 12</p></div><strong id=\"score-percent\">0%</strong></div>\r\n        <div class=\"exercise-actions\"><button class=\"reset-btn\" id=\"reset-exercises\" type=\"button\">Ricomincia</button><a class=\"button primary\" href=\"../\">Torna alla grammatica</a></div>\r\n      </article>\r\n    </div>\r\n  </section>\r\n\r\n  <section class=\"conversion-section\"><div class=\"container conversion-card\"><div><p class=\"eyebrow\">Parliamo del tuo passato</p><h2>La scelta dei tempi diventa chiara quando racconti una storia vera.</h2><p>In lezione possiamo usare foto, viaggi, ricordi e weekend per allenare passato prossimo e imperfetto insieme.</p></div><div class=\"conversion-actions\"><a class=\"button light\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></div></div></section>\r\n</main>\r\n<footer><div class=\"container footer-grid\"><div><strong>Italiano con Martin</strong><p>Grammatica chiara, letture graduate e lezioni online.</p></div><div><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a></div></div></footer>\r\n<script src=\"../../assets/grammar-exercises.js\"></script>\r\n<script src=\"../../script.js\"></script></body>\r\n</html>\r\n\r\n\r\n\r\n";
