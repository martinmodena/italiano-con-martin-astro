const documentHtml = "<!doctype html>\n<!-- Generated from legacy-html by scripts/import-html.mjs: grammatica/a2/imperfetto.html -->\r\n<html lang=\"it\">\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\r\n  <title>Imperfetto - livello A2 | Italiano con Martin</title>\r\n  <meta name=\"description\" content=\"Impara l'imperfetto italiano con usi, coniugazioni, esempi quotidiani, errori comuni ed esercizi interattivi.\">\r\n  \r\n  <link rel=\"canonical\" href=\"https://italianoconmartin.com/grammatica/a2/imperfetto.html\">\r\n  <meta name=\"robots\" content=\"index,follow,max-image-preview:large\">\r\n  <meta name=\"author\" content=\"Martin Modena\">\r\n  <meta property=\"og:type\" content=\"website\">\r\n  <meta property=\"og:site_name\" content=\"Italiano con Martin\">\r\n  <meta property=\"og:title\" content=\"Imperfetto - livello A2 | Italiano con Martin\">\r\n  <meta property=\"og:description\" content=\"Impara l'imperfetto italiano con usi, coniugazioni, esempi quotidiani, errori comuni ed esercizi interattivi.\">\r\n  <meta property=\"og:url\" content=\"https://italianoconmartin.com/grammatica/a2/imperfetto.html\">\r\n  <meta property=\"og:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\r\n  <meta name=\"twitter:title\" content=\"Imperfetto - livello A2 | Italiano con Martin\">\r\n  <meta name=\"twitter:description\" content=\"Impara l'imperfetto italiano con usi, coniugazioni, esempi quotidiani, errori comuni ed esercizi interattivi.\">\r\n  <meta name=\"twitter:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <link rel=\"stylesheet\" href=\"../../styles.css\">\r\n  \r\n  <link rel=\"stylesheet\" href=\"../../assets/grammar-lesson.css\">\r\n<link rel=\"icon\" href=\"../../favicon.png\" type=\"image/png\"><link rel=\"apple-touch-icon\" href=\"../../apple-touch-icon.png\"></head>\r\n<body data-lesson=\"martin-imperfetto-a2\">\r\n<header class=\"site-header\"><div class=\"container nav-wrap\"><a class=\"brand\" href=\"../../\"><img class=\"brand-avatar\" src=\"../../assets/martin-photo.svg\" alt=\"Martin\"><span>Italiano con Martin</span></a><nav><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a><a class=\"nav-cta\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></nav></div></header>\r\n<main>\r\n  <section class=\"page-intro\">\r\n    <div class=\"container lesson-shell\">\r\n      <p class=\"breadcrumbs\"><a href=\"../../\">Home</a> / <a href=\"../\">Grammatica</a> / A2 / Imperfetto</p>\r\n      <p class=\"eyebrow\">Grammatica A2</p>\r\n      <h1>L'imperfetto</h1>\r\n      <p class=\"lead\">Impara a parlare di abitudini nel passato, descrizioni e situazioni in corso.</p>\r\n      <div class=\"lesson-meta\"><span>14 minuti</span><span>12 esercizi</span><span>Livello A2</span></div>\r\n      <div class=\"lesson-nav\"><a href=\"#uso\">Uso</a><a href=\"#forme\">Forme</a><a href=\"#errori\">Errori</a><a href=\"#esercizi\">Esercizi</a></div>\r\n    </div>\r\n  </section>\r\n\r\n  <section class=\"section compact-top\">\r\n    <div class=\"container lesson-shell\">\r\n      <article class=\"lesson-box\" id=\"uso\">\r\n        <h2>Quando usiamo l'imperfetto?</h2>\r\n        <div class=\"rule-grid\">\r\n          <div class=\"rule-card\"><strong>Abitudini nel passato</strong><br>Da bambino giocavo in giardino.</div>\r\n          <div class=\"rule-card\"><strong>Descrizioni</strong><br>La casa era piccola ma luminosa.</div>\r\n          <div class=\"rule-card\"><strong>Azioni in corso</strong><br>Mentre studiavo, ha telefonato Marco.</div>\r\n          <div class=\"rule-card\"><strong>Eta, ora, tempo</strong><br>Avevo dieci anni. Erano le otto. Pioveva.</div>\r\n        </div>\r\n        <p class=\"italian-box\"><strong>Come parla davvero un italiano?</strong><br>Per raccontare la tua vita, l'imperfetto &egrave; essenziale: <strong>Quando vivevo in Argentina, parlavo spesso italiano con mia nonna.</strong></p>\r\n      </article>\r\n\r\n      <article class=\"lesson-box\" id=\"forme\">\r\n        <h2>Forme regolari</h2>\r\n        <table class=\"conj-table\">\r\n          <thead><tr><th>Persona</th><th>parlare</th><th>credere</th><th>dormire</th></tr></thead>\r\n          <tbody>\r\n            <tr><td>io</td><td>parlavo</td><td>credevo</td><td>dormivo</td></tr>\r\n            <tr><td>tu</td><td>parlavi</td><td>credevi</td><td>dormivi</td></tr>\r\n            <tr><td>lui / lei</td><td>parlava</td><td>credeva</td><td>dormiva</td></tr>\r\n            <tr><td>noi</td><td>parlavamo</td><td>credevamo</td><td>dormivamo</td></tr>\r\n            <tr><td>voi</td><td>parlavate</td><td>credevate</td><td>dormivate</td></tr>\r\n            <tr><td>loro</td><td>parlavano</td><td>credevano</td><td>dormivano</td></tr>\r\n          </tbody>\r\n        </table>\r\n        <h3>Tre verbi importantissimi</h3>\r\n        <div class=\"example-grid\">\r\n          <div class=\"example\"><strong>essere</strong><br>ero, eri, era, eravamo, eravate, erano</div>\r\n          <div class=\"example\"><strong>avere</strong><br>avevo, avevi, aveva, avevamo, avevate, avevano</div>\r\n          <div class=\"example\"><strong>fare</strong><br>facevo, facevi, faceva, facevamo, facevate, facevano</div>\r\n          <div class=\"example\"><strong>dire</strong><br>dicevo, dicevi, diceva, dicevamo, dicevate, dicevano</div>\r\n        </div>\r\n      </article>\r\n\r\n      <article class=\"lesson-box\" id=\"errori\">\r\n        <h2>Errori che fanno quasi tutti</h2>\r\n        <div class=\"mistake-grid\">\r\n          <div class=\"mistake\"><strong>Errato: io era stanco.</strong>Corretto: io ero stanco.</div>\r\n          <div class=\"mistake\"><strong>Errato: noi parlava.</strong>Corretto: noi parlavamo.</div>\r\n          <div class=\"mistake\"><strong>Errato: quando ero bambino, sono giocato.</strong>Corretto: quando ero bambino, giocavo.</div>\r\n          <div class=\"mistake\"><strong>Errato: facevo una pizza ieri.</strong>Meglio: ieri ho fatto una pizza.</div>\r\n        </div>\r\n      </article>\r\n\r\n      <article class=\"lesson-box\" id=\"esercizi\">\r\n        <h2>Esercizi con feedback immediato</h2>\r\n        <p>Scrivi la forma corretta dell'imperfetto.</p>\r\n        <div class=\"exercise\" data-answer=\"parlavo\" data-hint=\"Con io: parlavo.\"><label>1. Da bambino io ___ poco. (parlare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"vivevi\" data-hint=\"Con tu: vivevi.\"><label>2. Tu ___ in Italia? (vivere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"era\" data-hint=\"Con lui/lei: era.\"><label>3. La casa ___ grande. (essere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"avevamo\" data-hint=\"Con noi: avevamo.\"><label>4. Noi ___ molto tempo. (avere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"dormivate\" data-hint=\"Con voi: dormivate.\"><label>5. Voi ___ fino a tardi. (dormire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"andavano\" data-hint=\"Con loro: andavano.\"><label>6. Loro ___ a scuola a piedi. (andare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"facevo\" data-hint=\"Fare all'imperfetto: facevo.\"><label>7. Io ___ colazione alle otto. (fare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"diceva\" data-hint=\"Dire all'imperfetto: diceva.\"><label>8. Marco ___ sempre la verit&agrave;. (dire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"pioveva\" data-hint=\"Per il tempo atmosferico: pioveva.\"><label>9. Ieri mattina ___ molto. (piovere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"studiavo\" data-hint=\"Azione in corso: studiavo.\"><label>10. Mentre ___, ha telefonato Anna. (studiare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"erano\" data-hint=\"Con le otto: erano.\"><label>11. ___ le otto quando sono uscito. (essere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"leggevano\" data-hint=\"Con loro: leggevano.\"><label>12. I bambini ___ una storia. (leggere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"score-card\"><div><strong>Il tuo risultato</strong><p id=\"score-text\">0 risposte corrette su 12</p></div><strong id=\"score-percent\">0%</strong></div>\r\n        <div class=\"exercise-actions\"><button class=\"reset-btn\" id=\"reset-exercises\" type=\"button\">Ricomincia</button><a class=\"button primary\" href=\"../\">Torna alla grammatica</a></div>\r\n      </article>\r\n    </div>\r\n  </section>\r\n\r\n  <section class=\"conversion-section\"><div class=\"container conversion-card\"><div><p class=\"eyebrow\">Racconta il tuo passato</p><h2>L'imperfetto rende le storie pi&ugrave; naturali.</h2><p>In una lezione possiamo parlare della tua infanzia, delle tue abitudini e dei luoghi in cui vivevi.</p></div><div class=\"conversion-actions\"><a class=\"button light\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></div></div></section>\r\n</main>\r\n<footer><div class=\"container footer-grid\"><div><strong>Italiano con Martin</strong><p>Grammatica chiara, letture graduate e lezioni online.</p></div><div><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a></div></div></footer>\r\n<script src=\"../../assets/grammar-exercises.js\"></script>\r\n<script src=\"../../script.js\"></script></body>\r\n</html>\r\n\r\n\r\n\r\n";
