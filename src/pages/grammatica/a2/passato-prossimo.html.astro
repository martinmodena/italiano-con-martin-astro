---
const documentHtml = "<!doctype html>\n<!-- Generated from legacy-html by scripts/import-html.mjs: grammatica/a2/passato-prossimo.html -->\r\n<html lang=\"it\">\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\r\n  <title>Passato prossimo - livello A2 | Italiano con Martin</title>\r\n  <meta name=\"description\" content=\"Impara il passato prossimo in italiano con essere e avere, participi passati, esempi ed esercizi interattivi.\">\r\n  \r\n  <link rel=\"canonical\" href=\"https://italianoconmartin.com/grammatica/a2/passato-prossimo.html\">\r\n  <meta name=\"robots\" content=\"index,follow,max-image-preview:large\">\r\n  <meta name=\"author\" content=\"Martin Modena\">\r\n  <meta property=\"og:type\" content=\"website\">\r\n  <meta property=\"og:site_name\" content=\"Italiano con Martin\">\r\n  <meta property=\"og:title\" content=\"Passato prossimo - livello A2 | Italiano con Martin\">\r\n  <meta property=\"og:description\" content=\"Impara il passato prossimo in italiano con essere e avere, participi passati, esempi ed esercizi interattivi.\">\r\n  <meta property=\"og:url\" content=\"https://italianoconmartin.com/grammatica/a2/passato-prossimo.html\">\r\n  <meta property=\"og:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\r\n  <meta name=\"twitter:title\" content=\"Passato prossimo - livello A2 | Italiano con Martin\">\r\n  <meta name=\"twitter:description\" content=\"Impara il passato prossimo in italiano con essere e avere, participi passati, esempi ed esercizi interattivi.\">\r\n  <meta name=\"twitter:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <link rel=\"stylesheet\" href=\"../../styles.css\">\r\n  \r\n  <link rel=\"stylesheet\" href=\"../../assets/grammar-lesson.css\">\r\n<link rel=\"icon\" href=\"../../favicon.png\" type=\"image/png\"><link rel=\"apple-touch-icon\" href=\"../../apple-touch-icon.png\"></head>\r\n<body data-lesson=\"martin-passato-prossimo-a2\">\r\n<header class=\"site-header\"><div class=\"container nav-wrap\"><a class=\"brand\" href=\"../../\"><img class=\"brand-avatar\" src=\"../../assets/martin-photo.svg\" alt=\"Martin\" width=\"48\" height=\"48\" decoding=\"async\"><span>Italiano con Martin</span></a><nav><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a><a class=\"nav-cta\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></nav></div></header>\r\n<main>\r\n  <section class=\"page-intro\"><div class=\"container lesson-shell\"><p class=\"breadcrumbs\"><a href=\"../../\">Home</a> / <a href=\"../\">Grammatica</a> / A2 / Passato prossimo</p><p class=\"eyebrow\">Grammatica A2</p><h1>Il passato prossimo</h1><p class=\"lead\">Impara a raccontare azioni finite: ieri ho studiato, sono andato, abbiamo mangiato.</p><div class=\"lesson-meta\"><span>15 minuti</span><span>12 esercizi</span><span>Livello A2</span></div><div class=\"lesson-nav\"><a href=\"#forma\">Forma</a><a href=\"#ausiliare\">Essere o avere</a><a href=\"#errori\">Errori</a><a href=\"#esercizi\">Esercizi</a></div></div></section>\r\n  <section class=\"section compact-top\"><div class=\"container lesson-shell\">\r\n    <article class=\"lesson-box\" id=\"forma\">\r\n      <h2>Come si forma?</h2>\r\n      <p>Il passato prossimo si forma con <strong>avere</strong> o <strong>essere</strong> al presente + participio passato.</p>\r\n      <table class=\"conj-table\"><thead><tr><th>Verbo</th><th>Participio</th><th>Esempio</th></tr></thead><tbody><tr><td>parlare</td><td>parlato</td><td>Ho parlato con Maria.</td></tr><tr><td>credere</td><td>creduto</td><td>Abbiamo creduto alla storia.</td></tr><tr><td>dormire</td><td>dormito</td><td>Hai dormito bene?</td></tr><tr><td>andare</td><td>andato</td><td>Sono andato a Roma.</td></tr></tbody></table>\r\n      <p class=\"mini-note\"><strong>Formula:</strong> ho / hai / ha / abbiamo / avete / hanno + participio oppure sono / sei / &egrave; / siamo / siete / sono + participio.</p>\r\n    </article>\r\n\r\n    <article class=\"lesson-box\" id=\"ausiliare\">\r\n      <h2>Essere o avere?</h2>\r\n      <div class=\"rule-grid\"><div class=\"rule-card\"><strong>Avere</strong><br>Molti verbi usano avere: ho mangiato, ho studiato, ho visto.</div><div class=\"rule-card\"><strong>Essere</strong><br>Movimento o cambiamento: sono andato, sono arrivato, sono nato.</div><div class=\"rule-card\"><strong>Con essere cambia la finale</strong><br>Marco &egrave; andato. Anna &egrave; andata.</div><div class=\"rule-card\"><strong>Plurale</strong><br>Marco e Luca sono andati. Anna e Sara sono andate.</div></div>\r\n    </article>\r\n\r\n    <article class=\"lesson-box\" id=\"errori\">\r\n      <h2>Errori che fanno quasi tutti</h2>\r\n      <div class=\"mistake-grid\"><div class=\"mistake\"><strong>Errato: io sono mangiato.</strong>Corretto: io ho mangiato.</div><div class=\"mistake\"><strong>Errato: lei ha andato.</strong>Corretto: lei &egrave; andata.</div><div class=\"mistake\"><strong>Errato: noi abbiamo arrivato.</strong>Corretto: noi siamo arrivati.</div><div class=\"mistake\"><strong>Errato: Anna &egrave; andato.</strong>Corretto: Anna &egrave; andata.</div></div>\r\n    </article>\r\n\r\n    <article class=\"lesson-box\" id=\"esercizi\">\r\n      <h2>Esercizi con feedback immediato</h2>\r\n      <p>Scrivi la forma corretta del passato prossimo.</p>\r\n      <div class=\"exercise\" data-answer=\"ho mangiato\" data-hint=\"Mangiare usa avere: ho mangiato.\"><label>1. Io ___ una pizza. (mangiare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"sei andato\" data-alt=\"sei andata\" data-hint=\"Andare usa essere: sei andato/andata.\"><label>2. Tu ___ al lavoro. (andare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"ha studiato\" data-hint=\"Studiare usa avere: ha studiato.\"><label>3. Lei ___ italiano. (studiare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"siamo arrivati\" data-alt=\"siamo arrivate\" data-hint=\"Arrivare usa essere e concorda con il soggetto.\"><label>4. Noi ___ tardi. (arrivare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"avete visto\" data-hint=\"Vedere usa avere: avete visto.\"><label>5. Voi ___ il film. (vedere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"sono partiti\" data-alt=\"sono partite\" data-hint=\"Partire usa essere e concorda con il soggetto.\"><label>6. Loro ___ ieri. (partire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"ho dormito\" data-hint=\"Dormire usa avere: ho dormito.\"><label>7. Io ___ otto ore. (dormire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"&egrave; nata\" data-alt=\"è nata|e' nata\" data-hint=\"Nascere usa essere; Maria &egrave; femminile: &egrave; nata.\"><label>8. Maria ___ a Milano. (nascere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"abbiamo parlato\" data-hint=\"Parlare usa avere: abbiamo parlato.\"><label>9. Noi ___ con Martin. (parlare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"sono tornato\" data-alt=\"sono tornata\" data-hint=\"Tornare usa essere e concorda con il soggetto.\"><label>10. Io ___ a casa. (tornare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"hai letto\" data-hint=\"Leggere usa avere: hai letto.\"><label>11. Tu ___ questo libro? (leggere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"sono usciti\" data-alt=\"sono uscite\" data-hint=\"Uscire usa essere e concorda con il soggetto.\"><label>12. I ragazzi ___ alle otto. (uscire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"score-card\"><div><strong>Il tuo risultato</strong><p id=\"score-text\">0 risposte corrette su 12</p></div><strong id=\"score-percent\">0%</strong></div>\r\n      <div class=\"exercise-actions\"><button class=\"reset-btn\" id=\"reset-exercises\" type=\"button\">Ricomincia</button><a class=\"button primary\" href=\"../\">Torna alla grammatica</a></div>\r\n    </article>\r\n  </div></section>\r\n  <section class=\"conversion-section\"><div class=\"container conversion-card\"><div><p class=\"eyebrow\">Racconta la tua vita</p><h2>Il passato prossimo apre vere conversazioni.</h2><p>In una lezione possiamo parlare del tuo weekend, dei tuoi viaggi e delle tue esperienze.</p></div><div class=\"conversion-actions\"><a class=\"button light\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></div></div></section>\r\n</main>\r\n<footer><div class=\"container footer-grid\"><div><strong>Italiano con Martin</strong><p>Grammatica chiara, letture graduate e lezioni online.</p></div><div><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a></div></div></footer>\r\n<script src=\"../../assets/grammar-exercises.js\"></script>\r\n<script src=\"../../script.js\"></script></body>\r\n</html>\r\n\r\n\r\n\r\n";
