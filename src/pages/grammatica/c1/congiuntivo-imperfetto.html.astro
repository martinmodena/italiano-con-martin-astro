const documentHtml = "<!doctype html>\n<!-- Generated from legacy-html by scripts/import-html.mjs: grammatica/c1/congiuntivo-imperfetto.html -->\r\n<html lang=\"it\">\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\r\n  <title>Congiuntivo imperfetto - livello C1 | Italiano con Martin</title>\r\n  <meta name=\"description\" content=\"Impara il congiuntivo imperfetto italiano con concordanza dei tempi, esempi avanzati ed esercizi interattivi.\">\r\n  \r\n  <link rel=\"canonical\" href=\"https://italianoconmartin.com/grammatica/c1/congiuntivo-imperfetto.html\">\r\n  <meta name=\"robots\" content=\"index,follow,max-image-preview:large\">\r\n  <meta name=\"author\" content=\"Martin Modena\">\r\n  <meta property=\"og:type\" content=\"website\">\r\n  <meta property=\"og:site_name\" content=\"Italiano con Martin\">\r\n  <meta property=\"og:title\" content=\"Congiuntivo imperfetto - livello C1 | Italiano con Martin\">\r\n  <meta property=\"og:description\" content=\"Impara il congiuntivo imperfetto italiano con concordanza dei tempi, esempi avanzati ed esercizi interattivi.\">\r\n  <meta property=\"og:url\" content=\"https://italianoconmartin.com/grammatica/c1/congiuntivo-imperfetto.html\">\r\n  <meta property=\"og:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\r\n  <meta name=\"twitter:title\" content=\"Congiuntivo imperfetto - livello C1 | Italiano con Martin\">\r\n  <meta name=\"twitter:description\" content=\"Impara il congiuntivo imperfetto italiano con concordanza dei tempi, esempi avanzati ed esercizi interattivi.\">\r\n  <meta name=\"twitter:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <link rel=\"stylesheet\" href=\"../../styles.css\">\r\n  \r\n  <link rel=\"stylesheet\" href=\"../../assets/grammar-lesson.css\">\r\n  <link rel=\"icon\" href=\"../../favicon.png\" type=\"image/png\"><link rel=\"apple-touch-icon\" href=\"../../apple-touch-icon.png\">\r\n</head>\r\n<body data-lesson=\"martin-congiuntivo-imperfetto-c1\">\r\n<header class=\"site-header\"><div class=\"container nav-wrap\"><a class=\"brand\" href=\"../../\"><img class=\"brand-avatar\" src=\"../../assets/martin-photo.svg\" alt=\"Martin\"><span>Italiano con Martin</span></a><nav><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a><a class=\"nav-cta\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></nav></div></header>\r\n<main>\r\n  <section class=\"page-intro\"><div class=\"container lesson-shell\"><p class=\"breadcrumbs\"><a href=\"../../\">Home</a> / <a href=\"../\">Grammatica</a> / C1 / Congiuntivo imperfetto</p><p class=\"eyebrow\">Grammatica C1</p><h1>Il congiuntivo imperfetto</h1><p class=\"lead\">Usalo per opinioni, desideri e ipotesi riferiti al passato o a situazioni non reali.</p><div class=\"lesson-meta\"><span>18 minuti</span><span>10 esercizi</span><span>Livello C1</span></div><div class=\"lesson-nav\"><a href=\"#forme\">Forme</a><a href=\"#uso\">Uso</a><a href=\"#concordanza\">Concordanza</a><a href=\"#esercizi\">Esercizi</a></div></div></section>\r\n  <section class=\"section compact-top\"><div class=\"container lesson-shell\">\r\n    <article class=\"lesson-box\" id=\"forme\"><h2>Forme regolari e frequenti</h2><table class=\"conj-table\"><thead><tr><th>Persona</th><th>Parlare</th><th>Prendere</th><th>Partire</th><th>Essere</th></tr></thead><tbody><tr><td>io</td><td>parlassi</td><td>prendessi</td><td>partissi</td><td>fossi</td></tr><tr><td>tu</td><td>parlassi</td><td>prendessi</td><td>partissi</td><td>fossi</td></tr><tr><td>lui / lei</td><td>parlasse</td><td>prendesse</td><td>partisse</td><td>fosse</td></tr><tr><td>noi</td><td>parlassimo</td><td>prendessimo</td><td>partissimo</td><td>fossimo</td></tr><tr><td>voi</td><td>parlaste</td><td>prendeste</td><td>partiste</td><td>foste</td></tr><tr><td>loro</td><td>parlassero</td><td>prendessero</td><td>partissero</td><td>fossero</td></tr></tbody></table></article>\r\n    <article class=\"lesson-box\" id=\"uso\"><h2>Quando lo usiamo?</h2><div class=\"rule-grid\"><div class=\"rule-card\"><strong>Opinione al passato</strong><br>Pensavo che fosse facile.</div><div class=\"rule-card\"><strong>Desiderio</strong><br>Vorrei che tu parlassi di più.</div><div class=\"rule-card\"><strong>Ipotesi</strong><br>Se avessi tempo, studierei.</div><div class=\"rule-card\"><strong>Dubbi nel passato</strong><br>Non sapevo se venisse.</div></div></article>\r\n    <article class=\"lesson-box\" id=\"concordanza\"><h2>Concordanza dei tempi</h2><p>Se il verbo principale è al passato o al condizionale, spesso il congiuntivo passa all'imperfetto.</p><div class=\"example-grid\"><div class=\"example\"><strong>Presente</strong><br>Penso che sia utile.</div><div class=\"example\"><strong>Passato</strong><br>Pensavo che fosse utile.</div><div class=\"example\"><strong>Condizionale</strong><br>Vorrei che tu venissi.</div><div class=\"example\"><strong>Desiderio non reale</strong><br>Mi piacerebbe che parlassimo più spesso.</div></div><p class=\"mini-note\"><strong>Attenzione:</strong> dopo “se” nell'ipotesi non usiamo il condizionale: se fossi, se avessi, se potessi.</p></article>\r\n    <article class=\"lesson-box\"><h2>Errori comuni</h2><div class=\"mistake-grid\"><div class=\"mistake\"><strong>Errato: se sarei.</strong>Corretto: se fossi.</div><div class=\"mistake\"><strong>Errato: volevo che vieni.</strong>Corretto: volevo che venissi.</div><div class=\"mistake\"><strong>Errato: pensavo che era.</strong>Corretto: pensavo che fosse.</div><div class=\"mistake\"><strong>Errato: vorrei che parli.</strong>Corretto: vorrei che parlassi.</div></div></article>\r\n    <article class=\"lesson-box\" id=\"esercizi\"><h2>Esercizi con feedback immediato</h2><p>Completa con il congiuntivo imperfetto.</p><div class=\"exercise\" data-answer=\"fossi\" data-hint=\"Essere: che io/tu fossi.\"><label>1. Pensavo che tu ___ a casa. (essere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"avesse\" data-hint=\"Avere: che lui/lei avesse.\"><label>2. Credevo che Maria ___ ragione. (avere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"parlassi\" data-hint=\"Parlare: che tu parlassi.\"><label>3. Vorrei che tu ___ più lentamente. (parlare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"venisse\" data-hint=\"Venire: che lui/lei venisse.\"><label>4. Speravo che Paolo ___ alla festa. (venire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"facessimo\" data-hint=\"Fare: che noi facessimo.\"><label>5. Sarebbe meglio che noi ___ pratica. (fare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"andaste\" data-hint=\"Andare: che voi andaste.\"><label>6. Non sapevo che voi ___ via. (andare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"potessi\" data-hint=\"Potere: se io potessi.\"><label>7. Se io ___, studierei ogni giorno. (potere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"studiassero\" data-hint=\"Studiare: che loro studiassero.\"><label>8. Volevo che gli studenti ___ di più. (studiare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"fossimo\" data-hint=\"Essere: che noi fossimo.\"><label>9. Mi sembrava che noi ___ pronti. (essere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"prendesse\" data-hint=\"Prendere: che lui/lei prendesse.\"><label>10. Preferirei che lei ___ il treno. (prendere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"score-card\"><div><strong>Il tuo risultato</strong><p id=\"score-text\">0 risposte corrette su 10</p></div><strong id=\"score-percent\">0%</strong></div><div class=\"exercise-actions\"><button class=\"reset-btn\" id=\"reset-exercises\" type=\"button\">Ricomincia</button><a class=\"button primary\" href=\"../\">Torna alla grammatica</a></div></article>\r\n  </div></section>\r\n  <section class=\"conversion-section\"><div class=\"container conversion-card\"><div><p class=\"eyebrow\">Italiano avanzato, ma chiaro</p><h2>Il congiuntivo diventa naturale con esempi personali.</h2><p>In una lezione possiamo usarlo per opinioni, desideri, ipotesi e racconti veri.</p></div><div class=\"conversion-actions\"><a class=\"button light\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></div></div></section>\r\n</main>\r\n<footer><div class=\"container footer-grid\"><div><strong>Italiano con Martin</strong><p>Grammatica chiara, letture graduate e lezioni online.</p></div><div><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a></div></div></footer><script src=\"../../assets/grammar-exercises.js\"></script>\r\n<script src=\"../../script.js\"></script></body>\r\n</html>\r\n\r\n\r\n";
