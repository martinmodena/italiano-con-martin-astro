const documentHtml = "<!doctype html>\n<!-- Generated from legacy-html by scripts/import-html.mjs: grammatica/a1/aggettivi-qualificativi.html -->\r\n<html lang=\"it\">\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\r\n  <title>Aggettivi qualificativi - livello A1 | Italiano con Martin</title>\r\n  <meta name=\"description\" content=\"Impara gli aggettivi qualificativi in italiano: accordo con genere e numero, posizione, esempi ed esercizi interattivi.\">\r\n  \r\n  <link rel=\"canonical\" href=\"https://italianoconmartin.com/grammatica/a1/aggettivi-qualificativi.html\">\r\n  <meta name=\"robots\" content=\"index,follow,max-image-preview:large\">\r\n  <meta name=\"author\" content=\"Martin Modena\">\r\n  <meta property=\"og:type\" content=\"website\">\r\n  <meta property=\"og:site_name\" content=\"Italiano con Martin\">\r\n  <meta property=\"og:title\" content=\"Aggettivi qualificativi - livello A1 | Italiano con Martin\">\r\n  <meta property=\"og:description\" content=\"Impara gli aggettivi qualificativi in italiano: accordo con genere e numero, posizione, esempi ed esercizi interattivi.\">\r\n  <meta property=\"og:url\" content=\"https://italianoconmartin.com/grammatica/a1/aggettivi-qualificativi.html\">\r\n  <meta property=\"og:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\r\n  <meta name=\"twitter:title\" content=\"Aggettivi qualificativi - livello A1 | Italiano con Martin\">\r\n  <meta name=\"twitter:description\" content=\"Impara gli aggettivi qualificativi in italiano: accordo con genere e numero, posizione, esempi ed esercizi interattivi.\">\r\n  <meta name=\"twitter:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <link rel=\"stylesheet\" href=\"../../styles.css\">\r\n  \r\n  <link rel=\"stylesheet\" href=\"../../assets/grammar-lesson.css\">\r\n<link rel=\"icon\" href=\"../../favicon.png\" type=\"image/png\"><link rel=\"apple-touch-icon\" href=\"../../apple-touch-icon.png\"></head>\r\n<body data-lesson=\"martin-aggettivi-a1\">\r\n<header class=\"site-header\"><div class=\"container nav-wrap\"><a class=\"brand\" href=\"../../\"><img class=\"brand-avatar\" src=\"../../assets/martin-photo.svg\" alt=\"Martin\" width=\"48\" height=\"48\" decoding=\"async\"><span>Italiano con Martin</span></a><nav><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a><a class=\"nav-cta\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></nav></div></header>\r\n<main>\r\n  <section class=\"page-intro\"><div class=\"container lesson-shell\"><p class=\"breadcrumbs\"><a href=\"../../\">Home</a> / <a href=\"../\">Grammatica</a> / A1 / Aggettivi</p><p class=\"eyebrow\">Grammatica A1</p><h1>Gli aggettivi qualificativi</h1><p class=\"lead\">Impara a descrivere persone, oggetti e luoghi: bello, grande, interessante, italiano.</p><div class=\"lesson-meta\"><span>10 minuti</span><span>10 esercizi</span><span>Livello A1</span></div><div class=\"lesson-nav\"><a href=\"#accordo\">Accordo</a><a href=\"#posizione\">Posizione</a><a href=\"#errori\">Errori</a><a href=\"#esercizi\">Esercizi</a></div></div></section>\r\n  <section class=\"section compact-top\"><div class=\"container lesson-shell\">\r\n    <article class=\"lesson-box\" id=\"accordo\">\r\n      <h2>La regola pi&ugrave; importante</h2>\r\n      <p>L'aggettivo cambia con il nome: maschile, femminile, singolare e plurale.</p>\r\n      <table class=\"conj-table\"><thead><tr><th>Tipo</th><th>Singolare</th><th>Plurale</th></tr></thead><tbody><tr><td>Maschile</td><td>un libro nuovo</td><td>libri nuovi</td></tr><tr><td>Femminile</td><td>una casa nuova</td><td>case nuove</td></tr><tr><td>Aggettivi in -e</td><td>un corso interessante</td><td>corsi interessanti</td></tr></tbody></table>\r\n      <p class=\"mini-note\"><strong>Ricorda:</strong> molti aggettivi in <strong>-e</strong> sono uguali al maschile e al femminile singolare: un film interessante, una lezione interessante.</p>\r\n    </article>\r\n\r\n    <article class=\"lesson-box\" id=\"posizione\">\r\n      <h2>Dove mettiamo l'aggettivo?</h2>\r\n      <p>Di solito l'aggettivo va dopo il nome, soprattutto quando descrive una qualit&agrave; concreta.</p>\r\n      <div class=\"example-grid\"><div class=\"example\">una macchina rossa</div><div class=\"example\">un ragazzo gentile</div><div class=\"example\">una lezione utile</div><div class=\"example\">un esercizio facile</div></div>\r\n      <p>Alcuni aggettivi molto comuni possono andare prima del nome: <strong>un bel giorno</strong>, <strong>una buona idea</strong>, <strong>un piccolo problema</strong>.</p>\r\n    </article>\r\n\r\n    <article class=\"lesson-box\" id=\"errori\">\r\n      <h2>Errori che fanno quasi tutti</h2>\r\n      <div class=\"mistake-grid\"><div class=\"mistake\"><strong>Errato: una casa nuovo.</strong>Corretto: una casa nuova.</div><div class=\"mistake\"><strong>Errato: libri nuova.</strong>Corretto: libri nuovi.</div><div class=\"mistake\"><strong>Errato: una lezione interessanta.</strong>Corretto: una lezione interessante.</div><div class=\"mistake\"><strong>Errato: due studenti gentile.</strong>Corretto: due studenti gentili.</div></div>\r\n    </article>\r\n\r\n    <article class=\"lesson-box\" id=\"esercizi\">\r\n      <h2>Esercizi con feedback immediato</h2>\r\n      <p>Scrivi la forma corretta dell'aggettivo.</p>\r\n      <div class=\"exercise\" data-answer=\"nuova\" data-hint=\"Casa &egrave; femminile singolare: nuova.\"><label>1. una casa ___ (nuovo)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"nuovi\" data-hint=\"Libri sono maschili plurali: nuovi.\"><label>2. due libri ___ (nuovo)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"interessante\" data-hint=\"Gli aggettivi in -e sono uguali al singolare.\"><label>3. una lezione ___ (interessante)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"interessanti\" data-hint=\"Al plurale gli aggettivi in -e diventano -i.\"><label>4. due lezioni ___ (interessante)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"italiana\" data-hint=\"Ragazza &egrave; femminile singolare: italiana.\"><label>5. una ragazza ___ (italiano)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"italiani\" data-hint=\"Studenti sono maschili plurali: italiani.\"><label>6. studenti ___ (italiano)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"facile\" data-hint=\"Esercizio &egrave; singolare: facile.\"><label>7. un esercizio ___ (facile)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"facili\" data-hint=\"Esercizi &egrave; plurale: facili.\"><label>8. esercizi ___ (facile)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"gentile\" data-hint=\"Persona &egrave; singolare: gentile.\"><label>9. una persona ___ (gentile)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"exercise\" data-answer=\"gentili\" data-hint=\"Persone &egrave; plurale: gentili.\"><label>10. persone ___ (gentile)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n      <div class=\"score-card\"><div><strong>Il tuo risultato</strong><p id=\"score-text\">0 risposte corrette su 10</p></div><strong id=\"score-percent\">0%</strong></div>\r\n      <div class=\"exercise-actions\"><button class=\"reset-btn\" id=\"reset-exercises\" type=\"button\">Ricomincia</button><a class=\"button primary\" href=\"../\">Torna al percorso</a></div>\r\n    </article>\r\n  </div></section>\r\n  <section class=\"conversion-section\"><div class=\"container conversion-card\"><div><p class=\"eyebrow\">Parla con pi&ugrave; precisione</p><h2>Descrivere bene &egrave; il primo passo per raccontare.</h2><p>In lezione useremo gli aggettivi per parlare di persone, viaggi, lavoro e vita quotidiana.</p></div><div class=\"conversion-actions\"><a class=\"button light\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></div></div></section>\r\n</main>\r\n<footer><div class=\"container footer-grid\"><div><strong>Italiano con Martin</strong><p>Grammatica chiara, letture graduate e lezioni online.</p></div><div><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a></div></div></footer>\r\n<script src=\"../../assets/grammar-exercises.js\"></script>\r\n<script src=\"../../script.js\"></script></body>\r\n</html>\r\n\r\n\r\n\r\n";
---

<Fragment set:html={documentHtml} />
