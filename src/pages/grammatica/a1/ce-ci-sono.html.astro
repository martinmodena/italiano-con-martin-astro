const documentHtml = "<!doctype html>\n<!-- Generated from legacy-html by scripts/import-html.mjs: grammatica/a1/ce-ci-sono.html -->\r\n<html lang=\"it\">\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\r\n  <title>C'&egrave; e ci sono - livello A1 | Italiano con Martin</title>\r\n  <meta name=\"description\" content=\"Impara a usare c'&egrave; e ci sono in italiano con spiegazioni semplici, esempi reali ed esercizi interattivi.\">\r\n  \r\n  <link rel=\"canonical\" href=\"https://italianoconmartin.com/grammatica/a1/ce-ci-sono.html\">\r\n  <meta name=\"robots\" content=\"index,follow,max-image-preview:large\">\r\n  <meta name=\"author\" content=\"Martin Modena\">\r\n  <meta property=\"og:type\" content=\"website\">\r\n  <meta property=\"og:site_name\" content=\"Italiano con Martin\">\r\n  <meta property=\"og:title\" content=\"C'&egrave; e ci sono - livello A1 | Italiano con Martin\">\r\n  <meta property=\"og:description\" content=\"Impara a usare c'&egrave; e ci sono in italiano con spiegazioni semplici, esempi reali ed esercizi interattivi.\">\r\n  <meta property=\"og:url\" content=\"https://italianoconmartin.com/grammatica/a1/ce-ci-sono.html\">\r\n  <meta property=\"og:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\r\n  <meta name=\"twitter:title\" content=\"C'&egrave; e ci sono - livello A1 | Italiano con Martin\">\r\n  <meta name=\"twitter:description\" content=\"Impara a usare c'&egrave; e ci sono in italiano con spiegazioni semplici, esempi reali ed esercizi interattivi.\">\r\n  <meta name=\"twitter:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <link rel=\"stylesheet\" href=\"../../styles.css\">\r\n  \r\n  <link rel=\"stylesheet\" href=\"../../assets/grammar-lesson.css\">\r\n<link rel=\"icon\" href=\"../../favicon.png\" type=\"image/png\"><link rel=\"apple-touch-icon\" href=\"../../apple-touch-icon.png\"></head>\r\n<body data-lesson=\"martin-ce-ci-sono-a1\">\r\n<header class=\"site-header\"><div class=\"container nav-wrap\"><a class=\"brand\" href=\"../../\"><img class=\"brand-avatar\" src=\"../../assets/martin-photo.svg\" alt=\"Martin\"><span>Italiano con Martin</span></a><nav><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a><a class=\"nav-cta\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></nav></div></header>\r\n<main>\r\n  <section class=\"page-intro\">\r\n    <div class=\"container lesson-shell\">\r\n      <p class=\"breadcrumbs\"><a href=\"../../\">Home</a> / <a href=\"../\">Grammatica</a> / A1 / C'&egrave; e ci sono</p>\r\n      <p class=\"eyebrow\">Grammatica A1</p>\r\n      <h1>C'&egrave; e ci sono</h1>\r\n      <p class=\"lead\">Impara a dire che una persona, una cosa o un luogo esiste o &egrave; presente.</p>\r\n      <div class=\"lesson-meta\"><span>8 minuti</span><span>10 esercizi</span><span>Livello A1</span></div>\r\n      <div class=\"lesson-nav\"><a href=\"#regola\">Regola</a><a href=\"#esempi\">Esempi</a><a href=\"#errori\">Errori</a><a href=\"#esercizi\">Esercizi</a></div>\r\n    </div>\r\n  </section>\r\n  <section class=\"section compact-top\">\r\n    <div class=\"container lesson-shell\">\r\n      <article class=\"lesson-box\" id=\"regola\">\r\n        <h2>Quando li usiamo?</h2>\r\n        <p>Usiamo <strong>c'&egrave;</strong> con una cosa singolare e <strong>ci sono</strong> con due o pi&ugrave; cose.</p>\r\n        <div class=\"rule-grid\">\r\n          <div class=\"rule-card\"><strong>C'&egrave; + singolare</strong><br>C'&egrave; una farmacia qui vicino.</div>\r\n          <div class=\"rule-card\"><strong>Ci sono + plurale</strong><br>Ci sono tre studenti in classe.</div>\r\n          <div class=\"rule-card\"><strong>Domanda</strong><br>C'&egrave; un bagno? Ci sono esercizi?</div>\r\n          <div class=\"rule-card\"><strong>Negativa</strong><br>Non c'&egrave; tempo. Non ci sono problemi.</div>\r\n        </div>\r\n        <p class=\"italian-box\"><strong>Come parla davvero un italiano?</strong><br>Per chiedere informazioni in modo naturale puoi dire: <strong>C'&egrave; una banca qui vicino?</strong></p>\r\n      </article>\r\n\r\n      <article class=\"lesson-box\" id=\"esempi\">\r\n        <h2>Esempi utili</h2>\r\n        <div class=\"example-grid\">\r\n          <div class=\"example\">Sul tavolo c'&egrave; un libro.</div>\r\n          <div class=\"example\">In cucina ci sono due sedie.</div>\r\n          <div class=\"example\">A Roma c'&egrave; molto traffico.</div>\r\n          <div class=\"example\">Nel corso ci sono studenti di molti paesi.</div>\r\n          <div class=\"example\">Non c'&egrave; problema.</div>\r\n          <div class=\"example\">Non ci sono domande.</div>\r\n        </div>\r\n      </article>\r\n\r\n      <article class=\"lesson-box\" id=\"errori\">\r\n        <h2>Errori che fanno quasi tutti</h2>\r\n        <div class=\"mistake-grid\">\r\n          <div class=\"mistake\"><strong>Errato: ci sono un libro.</strong>Corretto: c'&egrave; un libro.</div>\r\n          <div class=\"mistake\"><strong>Errato: c'&egrave; due persone.</strong>Corretto: ci sono due persone.</div>\r\n          <div class=\"mistake\"><strong>Errato: non c'&egrave; problemi.</strong>Corretto: non ci sono problemi.</div>\r\n          <div class=\"mistake\"><strong>Errato: ci e una farmacia.</strong>Corretto: c'&egrave; una farmacia.</div>\r\n        </div>\r\n      </article>\r\n\r\n      <article class=\"lesson-box\" id=\"esercizi\">\r\n        <h2>Esercizi con feedback immediato</h2>\r\n        <p>Scrivi <strong>c'&egrave;</strong> oppure <strong>ci sono</strong>.</p>\r\n        <div class=\"exercise\" data-answer=\"c&rsquo;&egrave;\" data-alt=\"c'e|c&egrave;\" data-hint=\"Una persona o una cosa singolare: c'&egrave;.\"><label>1. ___ un bar qui vicino.</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"ci sono\" data-hint=\"Due o pi&ugrave; cose: ci sono.\"><label>2. ___ tre libri sul tavolo.</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"c&rsquo;&egrave;\" data-alt=\"c'e|c&egrave;\" data-hint=\"Tempo &egrave; singolare: c'&egrave;.\"><label>3. Oggi non ___ tempo.</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"ci sono\" data-hint=\"Problemi sono plurali: ci sono.\"><label>4. Non ___ problemi.</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"c&rsquo;&egrave;\" data-alt=\"c'e|c&egrave;\" data-hint=\"Una farmacia: c'&egrave;.\"><label>5. ___ una farmacia in centro?</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"ci sono\" data-hint=\"Molte persone: ci sono.\"><label>6. In classe ___ molte persone.</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"c&rsquo;&egrave;\" data-alt=\"c'e|c&egrave;\" data-hint=\"Un messaggio: c'&egrave;.\"><label>7. Sul telefono ___ un messaggio.</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"ci sono\" data-hint=\"Due finestre: ci sono.\"><label>8. Nella stanza ___ due finestre.</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"c&rsquo;&egrave;\" data-alt=\"c'e|c&egrave;\" data-hint=\"Una domanda: c'&egrave;.\"><label>9. ___ una domanda importante.</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"exercise\" data-answer=\"ci sono\" data-hint=\"Tanti esercizi: ci sono.\"><label>10. Nel sito ___ tanti esercizi.</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div>\r\n        <div class=\"score-card\"><div><strong>Il tuo risultato</strong><p id=\"score-text\">0 risposte corrette su 10</p></div><strong id=\"score-percent\">0%</strong></div>\r\n        <div class=\"exercise-actions\"><button class=\"reset-btn\" id=\"reset-exercises\" type=\"button\">Ricomincia</button><a class=\"button primary\" href=\"aggettivi-qualificativi.html\">Prossima lezione</a></div>\r\n      </article>\r\n\r\n      <article class=\"lesson-box\">\r\n        <h2>Portalo nella conversazione</h2>\r\n        <div class=\"dialogue\">\r\n          <p><strong>Martin:</strong> Che cosa c'&egrave; nella tua stanza?</p>\r\n          <p><strong>Studente:</strong> C'&egrave; una scrivania e ci sono due sedie.</p>\r\n          <p><strong>Martin:</strong> Perfetto. Ora descriviamo anche la tua citt&agrave;.</p>\r\n        </div>\r\n      </article>\r\n    </div>\r\n  </section>\r\n  <section class=\"conversion-section\"><div class=\"container conversion-card\"><div><p class=\"eyebrow\">Dalla regola alla vita reale</p><h2>Descrivi la tua casa, la tua citt&agrave; e la tua giornata.</h2><p>In una lezione possiamo trasformare questa regola in una conversazione naturale.</p></div><div class=\"conversion-actions\"><a class=\"button light\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></div></div></section>\r\n</main>\r\n<footer><div class=\"container footer-grid\"><div><strong>Italiano con Martin</strong><p>Grammatica chiara, letture graduate e lezioni online.</p></div><div><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a></div></div></footer>\r\n<script src=\"../../assets/grammar-exercises.js\"></script>\r\n<script src=\"../../script.js\"></script></body>\r\n</html>\r\n\r\n\r\n\r\n";
