const documentHtml = "<!doctype html>\n<!-- Generated from legacy-html by scripts/import-html.mjs: grammatica/b2/congiuntivo-presente.html -->\r\n<html lang=\"it\">\r\n<head>\r\n  <meta charset=\"utf-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\r\n  <title>Congiuntivo presente - livello B2 | Italiano con Martin</title>\r\n  <meta name=\"description\" content=\"Impara il congiuntivo presente con opinioni, dubbi, emozioni, forme regolari e esercizi interattivi.\">\r\n  \r\n  <link rel=\"canonical\" href=\"https://italianoconmartin.com/grammatica/b2/congiuntivo-presente.html\">\r\n  <meta name=\"robots\" content=\"index,follow,max-image-preview:large\">\r\n  <meta name=\"author\" content=\"Martin Modena\">\r\n  <meta property=\"og:type\" content=\"website\">\r\n  <meta property=\"og:site_name\" content=\"Italiano con Martin\">\r\n  <meta property=\"og:title\" content=\"Congiuntivo presente - livello B2 | Italiano con Martin\">\r\n  <meta property=\"og:description\" content=\"Impara il congiuntivo presente con opinioni, dubbi, emozioni, forme regolari e esercizi interattivi.\">\r\n  <meta property=\"og:url\" content=\"https://italianoconmartin.com/grammatica/b2/congiuntivo-presente.html\">\r\n  <meta property=\"og:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <meta name=\"twitter:card\" content=\"summary_large_image\">\r\n  <meta name=\"twitter:title\" content=\"Congiuntivo presente - livello B2 | Italiano con Martin\">\r\n  <meta name=\"twitter:description\" content=\"Impara il congiuntivo presente con opinioni, dubbi, emozioni, forme regolari e esercizi interattivi.\">\r\n  <meta name=\"twitter:image\" content=\"https://italianoconmartin.com/assets/social-card.svg\">\r\n  <link rel=\"stylesheet\" href=\"../../styles.css\">\r\n  \r\n  <link rel=\"stylesheet\" href=\"../../assets/grammar-lesson.css\">\r\n  <link rel=\"icon\" href=\"../../favicon.png\" type=\"image/png\"><link rel=\"apple-touch-icon\" href=\"../../apple-touch-icon.png\">\r\n</head>\r\n<body data-lesson=\"martin-congiuntivo-presente-b2\">\r\n<header class=\"site-header\"><div class=\"container nav-wrap\"><a class=\"brand\" href=\"../../\"><img class=\"brand-avatar\" src=\"../../assets/martin-photo.svg\" alt=\"Martin\" width=\"48\" height=\"48\" decoding=\"async\"><span>Italiano con Martin</span></a><nav><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a><a class=\"nav-cta\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></nav></div></header>\r\n<main>\r\n  <section class=\"page-intro\"><div class=\"container lesson-shell\"><p class=\"breadcrumbs\"><a href=\"../../\">Home</a> / <a href=\"../\">Grammatica</a> / B2 / Congiuntivo presente</p><p class=\"eyebrow\">Grammatica B2</p><h1>Il congiuntivo presente</h1><p class=\"lead\">Usalo dopo opinioni, dubbi, emozioni e valutazioni: penso che sia, spero che venga.</p><div class=\"lesson-meta\"><span>16 minuti</span><span>10 esercizi</span><span>Livello B2</span></div><div class=\"lesson-nav\"><a href=\"#forma\">Forma</a><a href=\"#quando\">Quando usarlo</a><a href=\"#irregolari\">Irregolari</a><a href=\"#esercizi\">Esercizi</a></div></div></section>\r\n  <section class=\"section compact-top\"><div class=\"container lesson-shell\">\r\n    <article class=\"lesson-box\" id=\"forma\"><h2>Forme regolari</h2><table class=\"conj-table\"><thead><tr><th>Persona</th><th>Parlare</th><th>Prendere</th><th>Partire</th></tr></thead><tbody><tr><td>io</td><td>parli</td><td>prenda</td><td>parta</td></tr><tr><td>tu</td><td>parli</td><td>prenda</td><td>parta</td></tr><tr><td>lui / lei</td><td>parli</td><td>prenda</td><td>parta</td></tr><tr><td>noi</td><td>parliamo</td><td>prendiamo</td><td>partiamo</td></tr><tr><td>voi</td><td>parliate</td><td>prendiate</td><td>partiate</td></tr><tr><td>loro</td><td>parlino</td><td>prendano</td><td>partano</td></tr></tbody></table><p class=\"mini-note\"><strong>Importante:</strong> io, tu e lui/lei hanno spesso la stessa forma: che io parli, che tu parli, che lui parli.</p></article>\r\n    <article class=\"lesson-box\" id=\"quando\"><h2>Quando usarlo?</h2><div class=\"rule-grid\"><div class=\"rule-card\"><strong>Opinione non certa</strong><br>Penso che lui sia bravo.</div><div class=\"rule-card\"><strong>Dubbio</strong><br>Non so se venga oggi.</div><div class=\"rule-card\"><strong>Emozione</strong><br>Sono felice che tu studi italiano.</div><div class=\"rule-card\"><strong>Necessità</strong><br>È importante che voi parliate.</div></div><p class=\"italian-box\"><strong>Trucco pratico:</strong> dopo espressioni come penso che, credo che, spero che, è importante che, spesso serve il congiuntivo.</p></article>\r\n    <article class=\"lesson-box\" id=\"irregolari\"><h2>Irregolari fondamentali</h2><table class=\"conj-table\"><thead><tr><th>Verbo</th><th>Io / tu / lui</th><th>Noi</th><th>Voi</th><th>Loro</th></tr></thead><tbody><tr><td>essere</td><td>sia</td><td>siamo</td><td>siate</td><td>siano</td></tr><tr><td>avere</td><td>abbia</td><td>abbiamo</td><td>abbiate</td><td>abbiano</td></tr><tr><td>andare</td><td>vada</td><td>andiamo</td><td>andiate</td><td>vadano</td></tr><tr><td>fare</td><td>faccia</td><td>facciamo</td><td>facciate</td><td>facciano</td></tr><tr><td>venire</td><td>venga</td><td>veniamo</td><td>veniate</td><td>vengano</td></tr></tbody></table></article>\r\n    <article class=\"lesson-box\"><h2>Errori comuni</h2><div class=\"mistake-grid\"><div class=\"mistake\"><strong>Errato: penso che lui è bravo.</strong>Corretto: penso che lui sia bravo.</div><div class=\"mistake\"><strong>Errato: spero che tu vieni.</strong>Corretto: spero che tu venga.</div><div class=\"mistake\"><strong>Errato: è importante che voi parlate.</strong>Corretto: è importante che voi parliate.</div><div class=\"mistake\"><strong>Errato: credo che loro hanno tempo.</strong>Corretto: credo che loro abbiano tempo.</div></div></article>\r\n    <article class=\"lesson-box\" id=\"esercizi\"><h2>Esercizi con feedback immediato</h2><p>Completa con il congiuntivo presente.</p><div class=\"exercise\" data-answer=\"sia\" data-hint=\"Essere: che lui sia.\"><label>1. Penso che Marco ___ simpatico. (essere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"abbia\" data-hint=\"Avere: che tu abbia.\"><label>2. Spero che tu ___ tempo. (avere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"parli\" data-hint=\"Parlare: che lei parli.\"><label>3. Credo che Anna ___ bene italiano. (parlare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"prendiamo\" data-hint=\"Prendere: che noi prendiamo.\"><label>4. È meglio che noi ___ il treno. (prendere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"partiate\" data-hint=\"Partire: che voi partiate.\"><label>5. È necessario che voi ___ presto. (partire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"vadano\" data-hint=\"Andare: che loro vadano.\"><label>6. Dubito che loro ___ a casa. (andare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"faccia\" data-hint=\"Fare: che lei faccia.\"><label>7. Voglio che lei ___ attenzione. (fare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"venga\" data-hint=\"Venire: che lui venga.\"><label>8. Spero che Paolo ___ alla lezione. (venire)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"studino\" data-hint=\"Studiare: che loro studino.\"><label>9. Sono felice che gli studenti ___ molto. (studiare)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"exercise\" data-answer=\"siate\" data-hint=\"Essere: che voi siate.\"><label>10. Mi sembra che voi ___ pronti. (essere)</label><input autocomplete=\"off\"><div class=\"feedback\"></div></div><div class=\"score-card\"><div><strong>Il tuo risultato</strong><p id=\"score-text\">0 risposte corrette su 10</p></div><strong id=\"score-percent\">0%</strong></div><div class=\"exercise-actions\"><button class=\"reset-btn\" id=\"reset-exercises\" type=\"button\">Ricomincia</button><a class=\"button primary\" href=\"../\">Torna alla grammatica</a></div></article>\r\n  </div></section>\r\n  <section class=\"conversion-section\"><div class=\"container conversion-card\"><div><p class=\"eyebrow\">Italiano più avanzato</p><h2>Il congiuntivo si impara davvero usandolo.</h2><p>In lezione lo trasformiamo in frasi reali: opinioni, dubbi, speranze e discussioni.</p></div><div class=\"conversion-actions\"><a class=\"button light\" href=\"https://preply.com/it/tutor/5086125\" target=\"_blank\" rel=\"noopener\">Prenota su Preply</a></div></div></section>\r\n</main>\r\n<footer><div class=\"container footer-grid\"><div><strong>Italiano con Martin</strong><p>Grammatica chiara, letture graduate e lezioni online.</p></div><div><a href=\"../\">Grammatica</a><a href=\"../../letture/\">Letture</a></div></div></footer><script src=\"../../assets/grammar-exercises.js\"></script>\r\n<script src=\"../../script.js\"></script></body>\r\n</html>\r\n\r\n\r\n";
