---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Home',
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      { variant: 'primary', text: 'Apri la migrazione', href: '/migrazione', icon: 'tabler:file-text' },
      { text: 'AstroWind', href: 'https://github.com/arthelokyo/astrowind', target: '_blank' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'AstroWind' }}
  >
    <Fragment slot="title">Sito migrato in AstroWind</Fragment>
    <Fragment slot="subtitle">
      Base Astro pronta per importare le pagine HTML esistenti, mantenere gli URL statici e pubblicare su GitHub
      Pages tramite GitHub Actions.
    </Fragment>
  </Hero>

  <Features
    title="Cosa e gia configurato"
    items={[
      {
        title: 'Template AstroWind',
        description: 'Layout, componenti, Tailwind CSS e build statica sono gia pronti.',
        icon: 'tabler:template',
      },
      {
        title: 'Import HTML',
        description: 'Metti le pagine esistenti in legacy-html ed esegui npm run import:html.',
        icon: 'tabler:files',
      },
      {
        title: 'Deploy GitHub Pages',
        description: 'La workflow pubblica automaticamente la cartella dist dopo ogni push su main.',
        icon: 'tabler:brand-github',
      },
    ]}
  />

  <CallToAction
    title="Prossimo passo"
    subtitle="Aggiungi i file HTML originali nella cartella legacy-html e lancia lo script di import per generare le pagine Astro con gli stessi percorsi."
    actions={[{ variant: 'primary', text: 'Leggi la guida', href: '/migrazione' }]}
  />
</Layout>
