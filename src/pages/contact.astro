---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contatti',
};
---

<Layout metadata={metadata}>
  <main class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-bold tracking-tight dark:text-white">Contatti</h1>
    <p class="mt-6 text-lg text-muted">
      Pagina pronta per inserire i riferimenti di contatto del sito migrato.
    </p>
  </main>
</Layout>
